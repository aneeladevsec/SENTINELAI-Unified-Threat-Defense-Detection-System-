# SentinelAI Environment Configuration

# System
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Database
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///data/sentinelai.db
DB_PASSWORD=change_me_in_production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=your-super-secret-key-change-in-production

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost

# Network Configuration
NETWORK_INTERFACE=default
PACKET_CAPTURE_TIMEOUT=30

# ML Models
MODEL_BATCH_SIZE=32
INFERENCE_TIMEOUT_MS=50
ENSEMBLE_VOTING=majority

# Alert Notifications
SLACK_WEBHOOK_URL=
SLACK_ENABLED=False
EMAIL_ENABLED=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Twilio SMS (for alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Threat Intelligence
THREAT_INTEL_UPDATE_INTERVAL=3600
ALIENTVAULT_API_KEY=

# System Paths
DATA_PATH=./data
BACKUP_PATH=./data/backups
QUARANTINE_PATH=./data/quarantine
MODELS_PATH=./data/models

# Defense Configuration
AUTONOMOUS_MODE=False
AGGRESSIVE_MODE=False
AUTO_QUARANTINE=True
AUTO_PROCESS_KILL=False

# Prediction
PREDICTION_ENABLED=True
FORECAST_HORIZON=24

# Monitoring
HEALTH_CHECK_INTERVAL=60
METRICS_RETENTION_DAYS=30
